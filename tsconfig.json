{
  "compilerOptions": {
    "module": "esnext",
    //"rootDir": "./src",
    "moduleResolution": "bundler",
    "target": "esnext",

    "types": ["node"],

    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,

    "strict": true,
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "noUncheckedSideEffectImports": true,
    "moduleDetection": "force",
    "skipLibCheck": true,
    //"outDir": "./build"
  }
}
